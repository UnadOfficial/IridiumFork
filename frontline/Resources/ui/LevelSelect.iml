<Iris>
    <VBox gap="4">
        <Text text={localize('LevelSelectSettings')} style="title" />
        <Separator />

        <HBox align="center">
            <Text text={localize('LevelSelectSettings')} style="label" />
            <Switch value={settings.lobbyMusic.enableLobbyMusicPatch} on-changed="OnLobbyMusicPatchToggled" />
        </HBox>

        {settings.lobbyMusic.enableLobbyMusicPatch && <>
            <Separator />

            <HBox align="center">
                <Text text={localize('EnableCustomBpm')} style="label" />
                <Switch value={settings.lobbyMusic.enableCustomBpm} on-changed="OnEnableCustomBpmToggled" />
            </HBox>

            {settings.lobbyMusic.enableCustomBpm && <>
                <HBox align="center">
                    <Text text={localize('CustomBpm')} style="label" />
                    <Slider value={settings.lobbyMusic.customBpm} min="60" max="240" step="1" showValue="true" on-changed="OnCustomBpmChanged" />
                </HBox>
            </>}

            <HBox align="center">
                <Text text={localize('LobbyFastMusic')} style="label" />
                <Switch value={settings.lobbyMusic.fastMusic} on-changed="OnLobbyFastMusicToggled" />
            </HBox>

            <HBox align="center">
                <Text text={localize('LobbyCustomMusic')} style="label" />
                <Switch value={settings.lobbyMusic.customMusic} on-changed="OnLobbyCustomMusicToggled" />
            </HBox>

            {settings.lobbyMusic.customMusic && <>
                <Separator />

                <HBox align="center">
                    <Text text={localize('LobbyDefaultMusicPath')} style="label" />
                    <TextField value={defaultMusicPath} on-text-submit="OnDefaultMusicPathChanged" />
                    <Button text={localize('Apply')} on-click="OnApplyDefaultMusic" />
                </HBox>

                <HBox align="center">
                    <Text text={localize('LobbyFastMusicPath')} style="label" />
                    <TextField value={fastMusicPath} on-text-submit="OnFastMusicPathChanged" />
                    <Button text={localize('Apply')} on-click="OnApplyFastMusic" />
                </HBox>

                <Button text={localize('LobbyReloadMusic')} on-click="OnLobbyReloadMusic" />
            </>}
        </>}
    </VBox>
</Iris>

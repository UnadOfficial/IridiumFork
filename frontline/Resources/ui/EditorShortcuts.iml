<Iris>
    <VBox gap="4">
        <Text text="{localize('EditorShortcuts')}" style="title" />
        <Separator />

        <HBox align="center">
            <Text text="{localize('EnableEditorShortcuts')}" style="label" />
            <Switch value="{settings.editorShortcuts.enableEditorShortcuts}" on-changed="OnEnableEditorShortcutsToggled" />
        </HBox>

        <If condition="{settings.editorShortcuts.enableEditorShortcuts}">
            <Separator />
            <Text text="{localize('EditorShortcutsDecoration')}" style="subtitle" />
            <Separator />

            <HBox align="center">
                <Text text="{localize('ShortcutSelectAll')}" style="label" />
                <Button text="{getShortcutDisplay(selectAllKey, selectAllModifiers)}" on-click="OnBindSelectAllKey" />
            </HBox>

            <HBox align="center">
                <Text text="{localize('ShortcutDeselectAll')}" style="label" />
                <Button text="{getShortcutDisplay(deselectAllKey, deselectAllModifiers)}" on-click="OnBindDeselectAllKey" />
            </HBox>

            <HBox align="center">
                <Text text="{localize('ShortcutToggleVisibility')}" style="label" />
                <Button text="{getShortcutDisplay(toggleVisibilityKey, toggleVisibilityModifiers)}" on-click="OnBindToggleVisibilityKey" />
            </HBox>

            <HBox align="center">
                <Text text="{localize('ShortcutFocusDecoration')}" style="label" />
                <Button text="{getShortcutDisplay(focusDecorationKey, focusDecorationModifiers)}" on-click="OnBindFocusDecorationKey" />
            </HBox>

            <Separator />
            <Text text="{localize('EditorShortcutsNavigation')}" style="subtitle" />
            <Separator />

            <HBox align="center">
                <Text text="{localize('ShortcutGoToFloor')}" style="label" />
                <Button text="{getShortcutDisplay(goToFloorKey, goToFloorModifiers)}" on-click="OnBindGoToFloorKey" />
            </HBox>

            <HBox align="center">
                <Text text="{localize('CameraFollowOnFloorSelect')}" style="label" />
                <Switch value="{settings.editorShortcuts.cameraFollowOnFloorSelect}" on-changed="OnCameraFollowOnFloorSelectToggled" />
            </HBox>

            <HBox align="center">
                <Text text="{localize('ShortcutSelectAllFloors')}" style="label" />
                <Button text="{getShortcutDisplay(selectAllFloorsKey, selectAllFloorsModifiers)}" on-click="OnBindSelectAllFloorsKey" />
            </HBox>

            <Separator />
            <Text text="{localize('EditorShortcutsPopup')}" style="subtitle" />
            <Separator />

            <HBox align="center">
                <Text text="{localize('ShortcutPopupSave')}" style="label" />
                <Button text="{getShortcutDisplay(popupSaveKey, popupSaveModifiers)}" on-click="OnBindPopupSaveKey" />
            </HBox>

            <HBox align="center">
                <Text text="{localize('ShortcutPopupDiscard')}" style="label" />
                <Button text="{getShortcutDisplay(popupDiscardKey, popupDiscardModifiers)}" on-click="OnBindPopupDiscardKey" />
            </HBox>
        </If>
    </VBox>
</Iris>

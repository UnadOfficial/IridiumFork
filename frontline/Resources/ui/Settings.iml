<Iris>
    <Resources>
        <Style name="title">
            <Setter property="color" value="#F8F9FA" />
        </Style>
        <Style name="subtitle">
            <Setter property="color" value="#F1F3F5" />
        </Style>
        <Style name="label">
            <Setter property="color" value="#E9ECEF" />
        </Style>
        <Style name="secondary">
            <Setter property="color" value="#7D7E7F" />
        </Style>
        <Style name="primary">
            <Setter property="background" value="#D973A5" />
            <Setter property="color" value="#FFFFFF" />
        </Style>
        <Style name="element">
            <Setter property="background" value="#313338" />
            <Setter property="color" value="#E9ECEF" />
        </Style>
    </Resources>

    <If condition="{settings.currentTab == 'optimizer'}">
        <Reference path="@Optimizer.iml" />
    </If>
    <If condition="{settings.currentTab == 'ui'}">
        <Reference path="@UISettings.iml" />
    </If>
    <If condition="{settings.currentTab == 'levelSelect'}">
        <Reference path="@LevelSelect.iml" />
    </If>
    <If condition="{settings.currentTab == 'compatibility'}">
        <Reference path="@Compatibility.iml" />
    </If>
    <If condition="{settings.currentTab == 'hitSound'}">
        <Reference path="@HitSound.iml" />
    </If>
    <If condition="{settings.currentTab == 'editorShortcuts'}">
        <Reference path="@EditorShortcuts.iml" />
    </If>
</Iris>

<Iris>
    <VBox gap="4">
        <Text text={localize('UISettings')} style="title" />
        <Separator />

        <HBox align="center">
            <Text text={localize('RemoveNews')} style="label" />
            <Switch value={settings.ui.removeNews} on-changed="OnRemoveNewsToggled" />
        </HBox>

        <HBox align="center">
            <Text text={localize('HideBetaWatermark')} style="label" />
            <Switch value={settings.ui.hideBetaWatermark} on-changed="OnHideBetaWatermarkToggled" />
        </HBox>

        <HBox align="center">
            <Text text={localize('ForceDifficultyUI')} style="label" />
            <Switch value={settings.ui.forceDifficultyUI} on-changed="OnForceDifficultyUIToggled" />
        </HBox>

        <HBox align="center">
            <Text text={localize('AlwaysCountdown')} style="label" />
            <Switch value={settings.ui.alwaysCountdown} on-changed="OnAlwaysCountdownToggled" />
        </HBox>

        <HBox align="center">
            <Text text={localize('EnablePausePlanetTrail')} style="label" />
            <Switch value={settings.ui.enablePausePlanetTrail} on-changed="OnEnablePausePlanetTrailToggled" />
        </HBox>

        <HBox align="center">
            <Text text={localize('MoveAutoplayText')} style="label" />
            <Switch value={settings.ui.moveAutoplayText} on-changed="OnMoveAutoplayTextToggled" />
        </HBox>

        {settings.ui.moveAutoplayText && <>
            <HBox align="center">
                <Text text="X:" style="label" />
                <Slider value={settings.ui.autoplayTextX} min="-500" max="500" showValue="true" on-changed="OnAutoplayTextXChanged" />
            </HBox>
            <HBox align="center">
                <Text text="Y:" style="label" />
                <Slider value={settings.ui.autoplayTextY} min="-300" max="300" showValue="true" on-changed="OnAutoplayTextYChanged" />
            </HBox>
        </>}

        <HBox align="center">
            <Text text={localize('EnableCircleArc')} style="label" />
            <Switch value={settings.ui.enableCircleArc} on-changed="OnEnableCircleArcToggled" />
        </HBox>
    </VBox>
</Iris>

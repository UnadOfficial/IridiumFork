<Iris>
    <Resources>
        <Style name="dialog">
            <background value="#151617" />
            <padding value="16,16,16,16" />
            <radius value="16" />
        </Style>
        <Style name="title">
            <color value="#F8F9FA" />
            <fontSize value="24" />
        </Style>
        <Style name="normal">
            <color value="#E9ECEF" />
            <fontSize value="12" />
        </Style>
        <Style name="primary">
            <background value="#D973A5" />
            <color value="#F8F9FA" />
            <fontSize value="12" />
            <radius value="8" />
        </Style>
        <Style name="element">
            <background value="#313338" />
            <color value="#F8F9FA" />
            <fontSize value="12" />
            <radius value="8" />
        </Style>
    </Resources>

    <VBox class="dialog" minWidth="400">
        <HBox gap="8">
            <If condition="{showIcon}">
                <Icon type="{iconType}" />
            </If>
            <Text text="{title}" style="title" />
        </HBox>
        <Spacer height="10" />
        <Text text="{message}" style="normal" />
        <Fill />
        <HBox gap="8">
            <Fill />
            <Button text="{btn1Text}" style="primary" visible="{hasBtn1}" on-click="OnBtn1" width="120" />
            <Button text="{btn2Text}" style="element" visible="{hasBtn2}" on-click="OnBtn2" width="120" />
        </HBox>
    </VBox>
</Iris>

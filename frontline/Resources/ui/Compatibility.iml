<Iris>
    <VBox gap="4">
        <Text text="{localize('CompatibilitySettings')}" style="title" />
        <Separator />

        <Text text="{localize('CompatibleBehavior')}" style="subtitle" />
        <Separator />

        <HBox align="center">
            <Text text="{localize('EnableLegacyPauseFix')}" style="label" />
            <Switch value="{settings.compatibility.enableLegacyPauseFix}" on-changed="OnEnableLegacyPauseFixToggled" />
        </HBox>

        <HBox align="center">
            <Text text="{localize('EnableNoFailTooEarly')}" style="label" />
            <Switch value="{settings.compatibility.enableNoFailTooEarly}" on-changed="OnEnableNoFailTooEarlyToggled" />
        </HBox>

        <HBox align="center">
            <Text text="{localize('ScaleFilterSpeedWithPitch')}" style="label" />
            <Switch value="{settings.compatibility.scaleFilterSpeedWithPitch}" on-changed="OnScaleFilterSpeedWithPitchToggled" />
        </HBox>

        <HBox align="center">
            <Text text="{localize('EditorPauseAllowed')}" style="label" />
            <Switch value="{settings.compatibility.editorPauseAllowed}" on-changed="OnEditorPauseAllowedToggled" />
        </HBox>

        <If condition="{settings.compatibility.editorPauseAllowed}">
            <HBox align="center">
                <Text text="{localize('EditorPauseEnabled')}" style="label" />
                <Fill />
                <Switch value="{settings.compatibility.editorPauseEnabled}" on-changed="OnEditorPauseEnabledToggled" />
            </HBox>
            <HBox align="center">
                <Text text="{localize('EditorPauseKey')}" style="label" />
                <Fill />
                <Button text="{getShortcutDisplay(settings.compatibility.editorPauseKey, settings.compatibility.editorPauseModifiers)}" on-click="OnBindEditorPauseKey" />
            </HBox>
        </If>

        <HBox align="center">
            <Text text="{localize('FixCameraRelativeDrag')}" style="label" />
            <Switch value="{settings.compatibility.fixCameraRelativeDrag}" on-changed="OnFixCameraRelativeDragToggled" />
        </HBox>

        <Separator />
        <Text text="{localize('BugFixes')}" style="subtitle" />
        <Separator />

        <HBox align="center">
            <Text text="{localize('PortalTravelFix')}" style="label" />
            <Switch value="{settings.compatibility.portalTravelFix}" on-changed="OnPortalTravelFixToggled" />
        </HBox>

        <HBox align="center">
            <Text text="{localize('FixEditorPlayResetMistakes')}" style="label" />
            <Switch value="{settings.compatibility.fixEditorPlayResetMistakes}" on-changed="OnFixEditorPlayResetMistakesToggled" />
        </HBox>

        <HBox align="center">
            <Text text="{localize('FixTurnaroundCondition')}" style="label" />
            <Switch value="{settings.compatibility.fixTurnaroundCondition}" on-changed="OnFixTurnaroundConditionToggled" />
        </HBox>

        <HBox align="center">
            <Text text="{localize('FixJudgeRotation')}" style="label" />
            <Switch value="{settings.compatibility.fixJudgeRotation}" on-changed="OnFixJudgeRotationToggled" />
        </HBox>

        <HBox align="center">
            <Text text="{localize('FixCoopPauseLock')}" style="label" />
            <Switch value="{settings.compatibility.fixCoopPauseLock}" on-changed="OnFixCoopPauseLockToggled" />
        </HBox>

        <Separator />
        <Text text="{localize('LegacyLevelBehavior')}" style="subtitle" />
        <Separator />

        <HBox align="center">
            <Text text="{localize('ForceAngleData')}" style="label" />
            <Switch value="{settings.compatibility.forceAngleData}" on-changed="OnForceAngleDataToggled" />
        </HBox>

        <Separator />
        <Text text="{localize('PatchMode')}" style="subtitle" />
        <Separator />

        <HBox align="center">
            <Text text="{localize('UseILPatch')}" style="label" />
            <Switch value="{settings.patchMode.useILPatch}" on-changed="OnUseILPatchToggled" />
        </HBox>
    </VBox>
</Iris>

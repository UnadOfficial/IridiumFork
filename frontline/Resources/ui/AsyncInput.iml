<Iris>
    <VBox class="padding">
        <Text text={localize('AsyncInputSettings')} style="title" />
        <HBox>
            <Text text={localize('EnableAsyncInput')} style="label" />
            <Fill />
            <Switch value={settings.asyncInput.enableAIO} on-changed="OnAsyncInputToggled" />
        </HBox>
        <Text text={localize('AsyncInputHint')} style="secondary" />
        <Text text={localize('AsyncInputWarning')} style="secondary" />
    </VBox>
</Iris>
